{
  "name": "@pictwo/core",
  "version": "1.1.0",
  "description": "URL-generation core for Pictwo — The open-source drop-in placeholder images service.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://pictwo.toneflix.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arkstack-hq/pictwo.git",
    "directory": "packages/pictwo-core"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"

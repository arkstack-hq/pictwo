{
  "name": "@pictwo/faker",
  "version": "1.0.0",
  "description": "Faker.js image module backed by the Pictwo placeholder image API.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://pictwo.toneflix.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arkstack-hq/pictwo.git",
    "directory": "packages/pictwo-faker"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pictwo/core": "workspace:*"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^25.6.2",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5"
  }
}

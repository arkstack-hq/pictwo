{
  "name": "@pictwo/faker",
  "version": "0.1.0",
  "description": "Faker.js image module backed by the Pictwo placeholder image API.",
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@pictwo/core": "workspace:*"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^25.6.2",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
{
    "apps": [
        {
            "name": "pictwo",
            "script": "./dist/server.js",
            "env": {
                "NODE_ENV": "development"
            },
            "env_production": {
                "NODE_ENV": "production"
            }
        },
        {
            "name": "pictwo-ssr",
            "script": "./node_modules/.bin/ark",
            "args": "inertia:ssr --no-restart",
            "interpreter": "none",
            "env": {
                "NODE_ENV": "development"
            },
            "env_production": {
                "NODE_ENV": "production"
            }
        }
    ]
}
